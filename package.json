{
  "name": "devstudio",
  "version": "1.0.0",
  "private": true,
  "description": "DevStudio - Root project to run both frontend and backend together",
  "scripts": {
    "start": "concurrently \"npm run start-frontend\" \"npm run start-backend\"",
    "start-frontend": "cd frontend && npm start",
    "start-backend": "cd backend && venv\\Scripts\\activate && python server.py"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
