# Copy this file to .env for local development. Set the same values in Vercel
# Project Settings -> Environment Variables for deployments.

MONGO_URI=mongodb+srv://<user>:<password>@<cluster-host>/devstudio?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
GROQ_API_KEY=replace-with-your-groq-api-key

# Optional. Comma-separated frontend origins allowed by CORS.
# Example: https://your-frontend.vercel.app,https://your-production-domain.com
CORS_ORIGINS=
FRONTEND_URL=

# Optional local override.
PORT=5000
