# MongoDB connection string. Replace <password> and <cluster-address> when using Atlas.
MONGO_URI=mongodb://127.0.0.1:27017/devstudio
# Example Atlas URI (replace values):
# MONGO_URI=mongodb+srv://devstudio:<password>@<cluster-address>.mongodb.net/devstudio?retryWrites=true&w=majority

# JWT secret for signing auth tokens
JWT_SECRET=your_jwt_secret_here

# Optional PORT override
PORT=5000
