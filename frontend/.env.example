# Copy this file to .env.local for local overrides.

# Required when the backend is deployed as a separate Vercel project.
# CRA bakes this value into the build, so set it before building/deploying.
# Example: https://your-backend-project.vercel.app
REACT_APP_BACKEND_URL=

# Optional. Defaults to the browser origin and is used for generated share links.
REACT_APP_FRONTEND_URL=
